# Supabase credentials
SUPABASE_URL=https://jrrrwukcasaqyqaidrme.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Default device for API queries
DEFAULT_DEVICE_NAME=pi-garden-01

# Sensor collector read interval in seconds (mirror pi-collector
# read_interval_seconds). Exposed on GET /health so the desktop can derive
# STALE_AFTER_MS = 2x interval. Default 30 matches pi-collector/config.yaml.
COLLECTOR_INTERVAL_SECONDS=30

# Alert engine background evaluation interval in seconds (default 60).
# The sidecar only evaluates while the desktop app is running.
ALERT_EVAL_INTERVAL_SECONDS=60
